void setup() {
  Serial.begin(115200);
  
  // Configuración Pines L298N (Chasis)
  pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT); pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  ledcAttach(ENA, 5000, 8); ledcAttach(ENB, 5000, 8);
  
  // Configuración Pines TB6612FNG (Montacargas)
  pinMode(AIN1, OUTPUT); pinMode(AIN2, OUTPUT); pinMode(STBY, OUTPUT);
  ledcAttach(PWMA, 5000, 8);
  digitalWrite(STBY, HIGH); // Activar siempre el driver TB6612FNG
  
  // Configuración Encoders
  pinMode(ENC_L_VERDE, INPUT_PULLUP); pinMode(ENC_R_VERDE, INPUT); 
  attachInterrupt(digitalPinToInterrupt(ENC_L_VERDE), isrL, RISING);
  attachInterrupt(digitalPinToInterrupt(ENC_R_VERDE), isrR, RISING);

  detenerTodo();
  
  WiFi.softAP(ssid, password);
  server.on("/", []() { server.send(200, "text/html", html_page); });
  
  server.on("/setPID", []() { usarPID = (server.arg("state") == "1"); server.send(200, "text/plain", "OK"); });
  server.on("/setPWM", []() {
    if (server.hasArg("l")) basePwmIzq = server.arg("l").toInt();
    if (server.hasArg("r")) basePwmDer = server.arg("r").toInt();
    if (moviendoAdelante && !usarPID) {
      pwmActualIzq = basePwmIzq; pwmActualDer = basePwmDer;
      ledcWrite(ENA, pwmActualIzq); ledcWrite(ENB, pwmActualDer);
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/cmd", []() {
    if (server.hasArg("action")) ejecutarComando(server.arg("action").charAt(0));
    server.send(200, "text/plain", "OK");
  });
  server.on("/encoders", []() {
    String j = "{\"izq\":" + String(countL) + ",\"der\":" + String(countR) + ",\"pwml\":" + String(pwmActualIzq) + ",\"pwmr\":" + String(pwmActualDer) + "}";
    server.send(200, "application/json", j);
  });
  
  server.begin();
  Serial.println("Sistema iniciado. Conéctate al WiFi y entra a 192.168.4.1");
}

void loop() {
  server.handleClient();
  if (moviendoAdelante && usarPID) { calcularPID(); }
}

void calcularPID() {
  unsigned long t = millis();
  if (t - tiempoAnteriorPID >= 50) {
    long dL = countL - prevCountL; long dR = countR - prevCountR;
    prevCountL = countL; prevCountR = countR;
    float error = dL - dR;
    errorAcumulado = constrain(errorAcumulado + error, -150, 150);
    float dErr = error - errorAnterior;
    float ajuste = (Kp * error) + (Ki * errorAcumulado) + (Kd * dErr);

    pwmActualIzq = basePwmIzq; pwmActualDer = basePwmDer;
    if (ajuste > 0) pwmActualIzq = constrain(basePwmIzq - ajuste, 100, 255);
    else pwmActualDer = constrain(basePwmDer + ajuste, 100, 255);

    ledcWrite(ENA, pwmActualIzq); ledcWrite(ENB, pwmActualDer);
    errorAnterior = error; tiempoAnteriorPID = t;
  }
}

void ejecutarComando(char c) {
  if (c == 'X') { detenerTodo(); return; }
  
  // Comandos de los Brazos
  if (c == 'U') { subirMontacargas(); return; }
  if (c == 'J') { bajarMontacargas(); return; }

  // Comandos del Chasis
  if (c == 'W') {
    if (!moviendoAdelante) { 
      prevCountL = countL; prevCountR = countR;
      errorAcumulado = 0; errorAnterior = 0;
      moviendoAdelante = true; 
      pwmActualIzq = basePwmIzq; pwmActualDer = basePwmDer;
    }
    adelante();
  } else {
    moviendoAdelante = false;
    pwmActualIzq = basePwmIzq; pwmActualDer = basePwmDer;
    ledcWrite(ENA, pwmActualIzq); ledcWrite(ENB, pwmActualDer);
    if(c=='S') atras(); else if(c=='A') izquierda(); else if(c=='D') derecha();
  }
}

// ================= FUNCIONES DE MOVIMIENTO CORREGIDAS =================

void adelante() { 
  // Invertido por software: Ahora avanza correctamente
  digitalWrite(IN1, LOW); digitalWrite(IN2, HIGH); 
  digitalWrite(IN3, LOW); digitalWrite(IN4, HIGH); 
  ledcWrite(ENA, pwmActualIzq); ledcWrite(ENB, pwmActualDer); 
}

void atras() { 
  // Invertido por software: Ahora retrocede correctamente
  digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW); 
  digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW); 
}

void izquierda() { 
  digitalWrite(IN1, LOW); digitalWrite(IN2, HIGH); 
  digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW); 
}

void derecha() { 
  digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW); 
  digitalWrite(IN3, LOW); digitalWrite(IN4, HIGH); 
}

void subirMontacargas() { 
  digitalWrite(AIN1, HIGH); digitalWrite(AIN2, LOW); 
  ledcWrite(PWMA, velocidadMontacargas); 
}

void bajarMontacargas() { 
  digitalWrite(AIN1, LOW); digitalWrite(AIN2, HIGH); 
  ledcWrite(PWMA, velocidadMontacargas); 
}

void detenerTodo() { 
  moviendoAdelante = false; 
  digitalWrite(IN1,0); digitalWrite(IN2,0); digitalWrite(IN3,0); digitalWrite(IN4,0); 
  ledcWrite(ENA,0); ledcWrite(ENB,0); 
  pwmActualIzq=0; pwmActualDer=0; 
  
  digitalWrite(AIN1, LOW); digitalWrite(AIN2, LOW);
  ledcWrite(PWMA, 0);
}
