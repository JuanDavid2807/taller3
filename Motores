#include <WiFi.h>
#include <WebServer.h>

// --- Configuración de Red WiFi ---
const char* ssid = "Robot_Diferencial_ESP32";
const char* password = "password123"; 

WebServer server(80);

// --- Pines del Chasis (L298N) ---
const int IN1 = 23;
const int IN2 = 19;
const int IN3 = 4;
const int IN4 = 2;
const int ENA = 13; 
const int ENB = 14; 
const int ENC_L_VERDE = 26;
const int ENC_R_VERDE = 34; 

// --- PINES DEL MONTACARGAS (TB6612FNG) ---
const int AIN1 = 22;   
const int AIN2 = 21;   
const int PWMA = 5;    
const int STBY = 15;   

volatile long countL = 0;
volatile long countR = 0;

void IRAM_ATTR isrL() { countL++; }
void IRAM_ATTR isrR() { countR++; }

// --- Variables de Control ---
bool moviendoAdelante = false;
bool usarPID = false; 
int basePwmIzq = 255; 
int basePwmDer = 255;
int velocidadMontacargas = 255; 

// Variables PID
unsigned long tiempoAnteriorPID = 0;
long prevCountL = 0; long prevCountR = 0;
float errorAcumulado = 0; float errorAnterior = 0;
float Kp = 1.2; float Ki = 0.05; float Kd = 0.1;  
int pwmActualIzq = 0; int pwmActualDer = 0;

// --- Interfaz HTML Unificada ---
const char html_page[] PROGMEM = R"rawliteral(
